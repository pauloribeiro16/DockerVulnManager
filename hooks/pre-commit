#!/bin/bash

# ==========================================
# DockerVulnManager - Pre-commit Security Hook
# Comprehensive file and security validation
# ==========================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

ERRORS_FOUND=0
WARNINGS_FOUND=0

echo -e "${BLUE}Running security pre-commit checks...${NC}"
echo "========================================"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || echo "")

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}No staged files to check${NC}"
    exit 0
fi

# ==========================================
# 1. FILE TYPE VALIDATION
# ==========================================
echo ""
echo "[1/9] Checking file types..."

ALLOWED_EXTENSIONS=(
    ".py" ".md" ".txt" ".toml" ".yaml" ".yml" ".json"
    ".sh" ".bash" ".cfg" ".ini" ".env.example"
    ".dockerignore" ".gitignore" ".gitattributes"
    "Dockerfile" "Dockerfile.*" "docker-compose*"
    ".html" ".css" ".js" ".ts"
    ".sql" ".db.example"
    "LICENSE" "Makefile" ".pre-commit-config.yaml"
)

BINARY_EXTENSIONS=(
    ".exe" ".dll" ".so" ".dylib" ".pyc" ".pyo"
    ".png" ".jpg" ".jpeg" ".gif" ".bmp" ".ico"
    ".zip" ".tar" ".gz" ".rar" ".7z"
    ".pdf" ".doc" ".docx" ".xls" ".xlsx"
    ".mp3" ".mp4" ".avi" ".mov"
    ".woff" ".woff2" ".ttf" ".eot"
    ".pkl" ".pickle" ".joblib"
    ".bin" ".dat" ".model" ".pt" ".pth"
    ".db" ".sqlite" ".sqlite3"
)

for file in $STAGED_FILES; do
    # Skip shell scripts and hooks (they may be detected as executable)
    BASENAME_FILE=$(basename "$file")
    if [[ "$file" == *.sh ]] || [[ "$BASENAME_FILE" == pre-commit ]] || [[ "$file" == .git/hooks/* ]]; then
        continue
    fi

    # Check if file is binary (only block actual binary/data files)
    FILE_TYPE=$(file "$file" 2>/dev/null || echo "")
    if echo "$FILE_TYPE" | grep -qE "ELF |executable,|binary|data$"; then
        echo -e "${RED}Binary file detected: $file${NC}"
        ERRORS_FOUND=$((ERRORS_FOUND + 1))
    fi

    # Check against blocked extensions
    for ext in "${BINARY_EXTENSIONS[@]}"; do
        if [[ "$file" == *"$ext" ]]; then
            echo -e "${RED}Blocked file type: $file ($ext)${NC}"
            ERRORS_FOUND=$((ERRORS_FOUND + 1))
        fi
    done
done

if [ $ERRORS_FOUND -eq 0 ]; then
    echo -e "${GREEN}All file types allowed${NC}"
fi

# ==========================================
# 2. FILE SIZE CHECK
# ==========================================
echo ""
echo "[2/9] Checking file sizes..."

MAX_FILE_SIZE=524288  # 512KB
LARGE_FILES=0

for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        SIZE=$(wc -c < "$file")
        if [ "$SIZE" -gt "$MAX_FILE_SIZE" ]; then
            SIZE_KB=$((SIZE / 1024))
            echo -e "${RED}Large file: $file (${SIZE_KB}KB > 512KB limit)${NC}"
            LARGE_FILES=$((LARGE_FILES + 1))
        fi
    fi
done

if [ $LARGE_FILES -eq 0 ]; then
    echo -e "${GREEN}All files under 512KB${NC}"
else
    ERRORS_FOUND=$((ERRORS_FOUND + LARGE_FILES))
fi

# ==========================================
# 3. CREDENTIAL DETECTION
# ==========================================
echo ""
echo "[3/9] Checking for credentials and secrets..."

CREDENTIAL_PATTERNS=(
    "AKIA[0-9A-Z]{16}"
    "api[_-]?key['\"]?\\s*[:=]\\s*['\"][A-Za-z0-9]{20,}"
    "password['\"]?\\s*[:=]\\s*['\"][^'\"]{8,}"
    "-----BEGIN (RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----"
    "gh[pousr]_[A-Za-z0-9_]{36,}"
    "token['\"]?\\s*[:=]\\s*['\"][A-Za-z0-9]{20,}"
    "(mongodb|postgres|mysql|redis|amqp)://[^:]+:[^@]+@"
    "secret['\"]?\\s*[:=]\\s*['\"][A-Za-z0-9+/]{40,}={0,2}"
    "xox[baprs]-[0-9]{10,}"
    "sk-[A-Za-z0-9]{40,}"
    "ghp_[A-Za-z0-9]{36}"
)

CRED_ERRORS=0
for file in $STAGED_FILES; do
    if [[ "$file" == *.md ]] || [[ "$file" == *.txt ]] || [[ "$file" == *.json ]]; then
        continue
    fi

    for pattern in "${CREDENTIAL_PATTERNS[@]}"; do
        if git diff --cached -- "$file" | grep -qP "$pattern" 2>/dev/null; then
            echo -e "${RED}Credential found in $file${NC}"
            CRED_ERRORS=$((CRED_ERRORS + 1))
        fi
    done
done

if [ $CRED_ERRORS -eq 0 ]; then
    echo -e "${GREEN}No credentials detected${NC}"
else
    ERRORS_FOUND=$((ERRORS_FOUND + CRED_ERRORS))
fi

# ==========================================
# 4. IP ADDRESS DETECTION
# ==========================================
echo ""
echo "[4/9] Checking for hardcoded IP addresses..."

IP_WARNINGS=0
for file in $STAGED_FILES; do
    if [[ "$file" == *.md ]] || [[ "$file" == *.txt ]] || [[ "$file" == *.json ]] || [[ "$file" == *.yaml ]] || [[ "$file" == *.yml ]]; then
        continue
    fi

    if [[ "$file" != *.py ]]; then
        continue
    fi

    # Only check actual code lines (skip comments and strings in docs)
    IPS=$(git diff --cached -- "$file" | grep -P '^\+' | grep -vP '^\+\s*#' | grep -oP '(?:\d{1,3}\.){3}\d{1,3}' 2>/dev/null | grep -vE '^(127\.0\.0\.1|0\.0\.0\.0|255\.255\.255\.255|8\.8\.8\.8|1\.1\.1\.1)$' || true)
    if [ -n "$IPS" ]; then
        echo -e "${YELLOW}Hardcoded IP in $file: $IPS${NC}"
        IP_WARNINGS=$((IP_WARNINGS + 1))
    fi
done

if [ $IP_WARNINGS -eq 0 ]; then
    echo -e "${GREEN}No hardcoded IPs detected${NC}"
else
    WARNINGS_FOUND=$((WARNINGS_FOUND + IP_WARNINGS))
fi

# ==========================================
# 5. RELATIVE PATH DETECTION
# ==========================================
echo ""
echo "[5/9] Checking for unsafe relative paths..."

PATH_ERRORS=0
for file in $STAGED_FILES; do
    if [[ "$file" != *.py ]]; then
        continue
    fi

    # Check for directory traversal
    if git diff --cached -- "$file" | grep -qP '\.\./.*\.\./' 2>/dev/null; then
        echo -e "${RED}Directory traversal in $file${NC}"
        PATH_ERRORS=$((PATH_ERRORS + 1))
    fi

    # Check for hardcoded user paths
    if git diff --cached -- "$file" | grep -qP '/home/[a-zA-Z0-9_]+/' 2>/dev/null; then
        echo -e "${RED}Hardcoded user path in $file${NC}"
        PATH_ERRORS=$((PATH_ERRORS + 1))
    fi
done

if [ $PATH_ERRORS -eq 0 ]; then
    echo -e "${GREEN}No unsafe paths detected${NC}"
else
    ERRORS_FOUND=$((ERRORS_FOUND + PATH_ERRORS))
fi

# ==========================================
# 6. SENSITIVE FILE DETECTION
# ==========================================
echo ""
echo "[6/9] Checking for sensitive files..."

SENSITIVE_FOUND=0
for file in $STAGED_FILES; do
    BASENAME=$(basename "$file")
    case "$BASENAME" in
        *.pem|*.key|*.p12|*.pfx|*.jks|.env|.env.local|.env.production|*.keystore|id_rsa|id_dsa|*.pfx)
            echo -e "${RED}Sensitive file blocked: $file${NC}"
            SENSITIVE_FOUND=$((SENSITIVE_FOUND + 1))
            ;;
    esac
done

if [ $SENSITIVE_FOUND -eq 0 ]; then
    echo -e "${GREEN}No sensitive files detected${NC}"
else
    ERRORS_FOUND=$((ERRORS_FOUND + SENSITIVE_FOUND))
fi

# ==========================================
# 7. PYTHON BEST PRACTICES
# ==========================================
echo ""
echo "[7/9] Checking Python best practices..."

PYTHON_WARNINGS=0
for file in $STAGED_FILES; do
    if [[ "$file" != *.py ]]; then
        continue
    fi

    # Check for dangerous patterns
    if git diff --cached -- "$file" | grep -qP '\bimport\s+pickle\b' 2>/dev/null; then
        echo -e "${YELLOW}pickle import in $file (security risk)${NC}"
        PYTHON_WARNINGS=$((PYTHON_WARNINGS + 1))
    fi

    if git diff --cached -- "$file" | grep -qP '\bimport\s+marshal\b' 2>/dev/null; then
        echo -e "${YELLOW}marshal import in $file (security risk)${NC}"
        PYTHON_WARNINGS=$((PYTHON_WARNINGS + 1))
    fi

    # Check for eval/exec
    if git diff --cached -- "$file" | grep -qP '\beval\s*\(' 2>/dev/null; then
        echo -e "${YELLOW}eval() usage in $file${NC}"
        PYTHON_WARNINGS=$((PYTHON_WARNINGS + 1))
    fi

    if git diff --cached -- "$file" | grep -qP '\bexec\s*\(' 2>/dev/null; then
        echo -e "${YELLOW}exec() usage in $file${NC}"
        PYTHON_WARNINGS=$((PYTHON_WARNINGS + 1))
    fi

    # Check for hardcoded passwords (only block actual string assignments, not env vars)
    if git diff --cached -- "$file" | grep -qP '^\+\s*\w*password\w*\s*=\s*["\x27][^"\x27]{8,}["\x27]' 2>/dev/null; then
        # Double-check it's not a test fixture or example
        if ! git diff --cached -- "$file" | grep -qP '^\+\s*\w*password\w*\s*=\s*["\x27](test|example|demo|changeme|placeholder)' 2>/dev/null; then
            echo -e "${RED}Hardcoded password in $file${NC}"
            ERRORS_FOUND=$((ERRORS_FOUND + 1))
        fi
    fi
done

if [ $PYTHON_WARNINGS -eq 0 ]; then
    echo -e "${GREEN}No critical Python issues detected${NC}"
else
    WARNINGS_FOUND=$((WARNINGS_FOUND + PYTHON_WARNINGS))
fi

# ==========================================
# 8. YAML/JSON VALIDATION
# ==========================================
echo ""
echo "[8/9] Validating configuration files..."

CONFIG_ERRORS=0
for file in $STAGED_FILES; do
    if [[ "$file" == *.yaml ]] || [[ "$file" == *.yml ]]; then
        if command -v python3 >/dev/null 2>&1; then
            if ! python3 -c "import yaml; yaml.safe_load(open('$file'))" 2>/dev/null; then
                echo -e "${RED}Invalid YAML: $file${NC}"
                CONFIG_ERRORS=$((CONFIG_ERRORS + 1))
            fi
        fi
    fi

    if [[ "$file" == *.json ]]; then
        if command -v python3 >/dev/null 2>&1; then
            if ! python3 -c "import json; json.load(open('$file'))" 2>/dev/null; then
                echo -e "${RED}Invalid JSON: $file${NC}"
                CONFIG_ERRORS=$((CONFIG_ERRORS + 1))
            fi
        fi
    fi

    # TOML validation
    if [[ "$file" == *.toml ]]; then
        if command -v python3 >/dev/null 2>&1; then
            if ! python3 -c "import tomllib; tomllib.load(open('$file', 'rb'))" 2>/dev/null; then
                echo -e "${RED}Invalid TOML: $file${NC}"
                CONFIG_ERRORS=$((CONFIG_ERRORS + 1))
            fi
        fi
    fi
done

if [ $CONFIG_ERRORS -eq 0 ]; then
    echo -e "${GREEN}All config files valid${NC}"
else
    ERRORS_FOUND=$((ERRORS_FOUND + CONFIG_ERRORS))
fi

# ==========================================
# 9. LINE ENDINGS AND ENCODING
# ==========================================
echo ""
echo "[9/9] Checking file encoding..."

ENCODING_ERRORS=0
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Check for non-UTF8 files (excluding binary)
        if [[ "$file" == *.py ]] || [[ "$file" == *.md ]] || [[ "$file" == *.txt ]] || [[ "$file" == *.json ]] || [[ "$file" == *.yaml ]] || [[ "$file" == *.yml ]] || [[ "$file" == *.toml ]]; then
            if ! iconv -f UTF-8 -t UTF-8 "$file" >/dev/null 2>&1; then
                echo -e "${RED}Non-UTF8 encoding: $file${NC}"
                ENCODING_ERRORS=$((ENCODING_ERRORS + 1))
            fi

            # Check for CRLF line endings
            if grep -qP '\r\n' "$file" 2>/dev/null; then
                echo -e "${YELLOW}CRLF line endings: $file (consider LF)${NC}"
                WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
            fi
        fi
    fi
done

if [ $ENCODING_ERRORS -eq 0 ]; then
    echo -e "${GREEN}All files UTF-8 encoded${NC}"
else
    ERRORS_FOUND=$((ERRORS_FOUND + ENCODING_ERRORS))
fi

# ==========================================
# SUMMARY
# ==========================================
echo ""
echo "========================================"
echo -e "Files checked: ${#STAGED_FILES[@]}"
if [ $ERRORS_FOUND -gt 0 ]; then
    echo -e "${RED}COMMIT BLOCKED: $ERRORS_FOUND error(s) found${NC}"
    echo -e "$WARNINGS_FOUND warning(s)"
    echo -e "${RED}Please fix errors before committing${NC}"
    exit 1
else
    echo -e "${GREEN}All security checks passed!${NC}"
    if [ $WARNINGS_FOUND -gt 0 ]; then
        echo -e "$WARNINGS_FOUND warning(s) (non-blocking)"
    fi
    exit 0
fi
